# AuditFlow Environment Variables (LOCAL DEVELOPMENT ONLY)

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=titi
POSTGRES_DB=auditflow
POSTGRES_HOST=postgres

# Application Ports
BACKEND_PORT=3000
POWERSYNC_PORT=8080

# JWT Configuration
JWT_SECRET=dev-jwt-secret-not-for-production

# PowerSync Configuration
POWERSYNC_JWT_SECRET=dev-powersync-jwt-secret

# Domains (production only - not used in dev)
APP_DOMAIN=auditflow.example.com
API_DOMAIN=api.auditflow.example.com

# Firebase Configuration (optional)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
